# select a revision to deploy, available values: stable, beta, canary
AFFINE_REVISION=stable

# set the port for the server container it will expose the server on
PORT=3010

# set the host for the server for outgoing links
AFFINE_SERVER_HTTPS=true
AFFINE_SERVER_HOST=affine.example.org
AFFINE_SERVER_EXTERNAL_URL=https://affine.example.org
AFFINE_BASIC_AUTH_USER=admin
AFFINE_BASIC_AUTH_PASSWORD=YOUR_PASSWORD_HERE

# AI mode only (default deployCompose.sh behavior):
# a token (random string of your choice) to secure the AI endpoint
# generate your own with:
# echo "sk-local-$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=sk-local-foobarfoobar

# AI mode only: optional AFFiNE Copilot key
# (if omitted, deployCompose.sh falls back to LITELLM_MASTER_KEY)
COPILOT_OPENAI_API_KEY=sk-local-foobarfoobar

# AI mode only: internal AI gateway URL
# (if omitted, deployCompose.sh falls back to http://caddy:80/v1)
AFFINE_OPENAI_API_URL=http://caddy:80/v1

# No-AI mode:
# Run ./deployCompose.sh --no-ai and leave AI variables above unset. It starts then only affine, postgres and redis.

# public Traefik gateway settings
TRAEFIK_PUBLIC_NETWORK=public-gateway
TRAEFIK_CONSTRAINT_LABEL=public-gateway
TRAEFIK_CERT_RESOLVER=myresolver

# position of the database data to persist
DB_DATA_LOCATION=./postgres/pgdata
# position of the upload data(images, files, etc.) to persist
UPLOAD_LOCATION=./storage
# position of the configuration files to persist
CONFIG_LOCATION=./config

# database credentials
DB_USERNAME=affine
DB_PASSWORD=letmein
DB_DATABASE=affine

# AI mode only: local LLM list (multiple comma separated)
OLLAMA_MODELS=llama3.2:3b,snowflake-arctic-embed:latest,codellama:7b-instruct

# remote deploy target for deployToServer.sh
SSH_SERVER=user@example.org
DEPLOY_REMOTE_DIR=affine-selfhosted
